---
// src/components/AIDisclosure.astro
// Neutral disclosure banner for AI-generated posts.
// Usage in MDX: import AIDisclosure from '@components/AIDisclosure.astro';
//               <AIDisclosure />
---

<aside
  class="not-prose flex items-center gap-3 rounded-lg border border-border-light dark:border-border px-4 py-3 my-6 bg-surface-light dark:bg-surface"
  role="note"
  aria-label="AI disclosure"
>
  <svg
    class="shrink-0 size-5 text-muted"
    viewBox="0 0 20 20"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <!-- sparkle icon -->
    <path d="M10 2v4M10 14v4M2 10h4M14 10h4M4.93 4.93l2.83 2.83M12.24 12.24l2.83 2.83M15.07 4.93l-2.83 2.83M7.76 12.24l-2.83 2.83" />
  </svg>
  <p class="text-sm text-muted leading-snug">
    This post was generated with the assistance of AI.
  </p>
</aside>
