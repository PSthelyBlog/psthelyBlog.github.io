---
// src/components/CopyCodeButton.astro
// This component injects copy buttons on all <pre> blocks via an inline script.
// Include it once in PostLayout.astro.
---

<script is:inline>
  (function() {
    function isDark() {
      return document.documentElement.classList.contains('dark');
    }

    function getColors() {
      if (isDark()) {
        return {
          bg: 'rgba(255,255,255,0.1)',
          color: '#e2e8f0',
          border: 'rgba(255,255,255,0.15)'
        };
      }
      return {
        bg: 'rgba(0,0,0,0.06)',
        color: '#374151',
        border: 'rgba(0,0,0,0.12)'
      };
    }

    function applyColors(btn) {
      var c = getColors();
      btn.style.background = c.bg;
      btn.style.color = c.color;
      btn.style.borderColor = c.border;
    }

    var buttons = [];

    document.querySelectorAll('pre').forEach(function(pre) {
      // Skip if already has a copy button
      if (pre.querySelector('.copy-code-btn')) return;

      // Create wrapper for positioning
      var wrapper = pre.parentElement;
      if (!wrapper || !wrapper.style) {
        // If pre is not inside a figure (rehype-pretty-code wraps in figure), wrap it
        wrapper = document.createElement('div');
        wrapper.style.position = 'relative';
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);
      } else {
        wrapper.style.position = 'relative';
      }

      var btn = document.createElement('button');
      btn.className = 'copy-code-btn';
      btn.setAttribute('aria-label', 'Copy code to clipboard');
      btn.style.cssText = 'position:absolute;top:0.5rem;right:0.5rem;padding:0.25rem 0.5rem;border-radius:0.375rem;font-size:0.75rem;cursor:pointer;opacity:0;transition:opacity 0.15s;z-index:10;';
      applyColors(btn);
      btn.textContent = 'Copy';
      buttons.push(btn);

      // Show on hover
      wrapper.addEventListener('mouseenter', function() { btn.style.opacity = '1'; });
      wrapper.addEventListener('mouseleave', function() {
        if (btn.textContent === 'Copy') btn.style.opacity = '0';
      });

      btn.addEventListener('click', function() {
        var code = pre.querySelector('code');
        var text = code ? code.textContent : pre.textContent;
        navigator.clipboard.writeText(text).then(function() {
          btn.textContent = 'Copied!';
          btn.style.opacity = '1';
          btn.style.background = 'rgba(0,200,150,0.2)';
          btn.style.borderColor = 'rgba(0,200,150,0.4)';
          setTimeout(function() {
            btn.textContent = 'Copy';
            btn.style.opacity = '0';
            applyColors(btn);
          }, 2000);
        });
      });

      wrapper.appendChild(btn);
    });

    // Re-apply colors when theme toggles
    var observer = new MutationObserver(function() {
      buttons.forEach(function(btn) {
        if (btn.textContent === 'Copy') applyColors(btn);
      });
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  })();
</script>
