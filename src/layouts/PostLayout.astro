---
// src/layouts/PostLayout.astro
import BaseLayout from '@layouts/BaseLayout.astro';
import TableOfContents from '@components/TableOfContents.astro';
import CopyCodeButton from '@components/CopyCodeButton.astro';
import CategoryBadge from '@components/CategoryBadge.astro';
import TagBadge from '@components/TagBadge.astro';
import Comments from '@components/Comments.astro';
import SupportCTA from '@components/SupportCTA.astro';
import { Image } from 'astro:assets';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      updatedDate?: Date;
      category: 'article' | 'tool' | 'guide' | 'case-study' | 'course';
      tags: string[];
      heroImage?: ImageMetadata;
      author: string;
      readingTime?: string;
      toolRating?: number;
    };
  };
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { post, headings } = Astro.props;
const { data } = post;

const DATE_FORMAT: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'long', day: 'numeric' };
const formatDate = (d: Date) => d.toLocaleDateString('en-US', DATE_FORMAT);

const formattedDate = formatDate(data.pubDate);
const formattedUpdatedDate = data.updatedDate ? formatDate(data.updatedDate) : null;
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.heroImage?.src}
  type="article"
  publishedDate={data.pubDate}
  modifiedDate={data.updatedDate}
  tags={data.tags}
>
  <article class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Post Header (with optional hero background) -->
    <header class:list={[
      "relative overflow-hidden mb-10 mx-auto",
      data.heroImage ? "rounded-xl -mx-4 sm:-mx-6 lg:mx-auto lg:max-w-5xl px-6 sm:px-10 py-14 sm:py-20" : "max-w-prose"
    ]}>
      {/* Hero image as dimmed/blurred background */}
      {data.heroImage && (
        <>
          <Image
            src={data.heroImage}
            alt=""
            class="absolute inset-0 w-full h-full object-cover blur-sm scale-105"
            widths={[400, 720, 1024]}
            sizes="(max-width: 720px) 100vw, 1024px"
          />
          <div class="absolute inset-0 bg-black/60"></div>
        </>
      )}

      <div class:list={["relative", data.heroImage ? "max-w-prose" : ""]}>
        <!-- Category + Date -->
        <div class="flex items-center gap-3 mb-4">
          <CategoryBadge category={data.category} />
          <time class:list={["text-sm", data.heroImage ? "text-white/70" : "text-muted"]} datetime={data.pubDate.toISOString()}>
            {formattedDate}
          </time>
          {data.readingTime && (
            <span class:list={["text-sm", data.heroImage ? "text-white/70" : "text-muted"]}>· {data.readingTime}</span>
          )}
        </div>

        <!-- Title -->
        <h1 class:list={[
          "font-heading text-4xl sm:text-5xl font-bold mb-4 leading-tight",
          data.heroImage ? "text-white" : "text-text-light dark:text-text"
        ]}>
          {data.title}
        </h1>

        <!-- Description -->
        <p class:list={["text-lg mb-4", data.heroImage ? "text-white/80" : "text-muted"]}>{data.description}</p>

        <!-- Author + Updated Date -->
        <div class:list={["flex items-center gap-4 text-sm", data.heroImage ? "text-white/70" : "text-muted"]}>
          <span>By {data.author}</span>
          {formattedUpdatedDate && (
            <span>· Updated {formattedUpdatedDate}</span>
          )}
        </div>

        <!-- Tags -->
        {data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {data.tags.map(tag => (
              <TagBadge tag={tag} />
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Content Area: TOC sidebar + Prose -->
    <div class="relative max-w-6xl mx-auto lg:grid lg:grid-cols-[1fr_220px] lg:gap-10">
      <!-- Main Content -->
      <div class="max-w-prose">
        <!-- Mobile TOC (inline, visible below lg) -->
        {headings.length >= 3 && (
          <div class="lg:hidden mb-8">
            <TableOfContents headings={headings} />
          </div>
        )}

        <!-- Prose Content -->
        <div class="prose prose-lg max-w-none">
          <slot />
        </div>

        <!-- Copy buttons on code blocks -->
        <CopyCodeButton />
      </div>

      <!-- Desktop TOC (sticky sidebar, visible at lg+) -->
      {headings.length >= 3 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <TableOfContents headings={headings} />
          </div>
        </aside>
      )}
    </div>

    <!-- Support CTA -->
    <div class="max-w-prose mx-auto mt-16">
      <SupportCTA />
    </div>

    <!-- Comments -->
    <div class="max-w-prose mx-auto mt-12">
      <Comments />
    </div>
  </article>
</BaseLayout>
