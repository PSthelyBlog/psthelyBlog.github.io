---
// src/pages/support.astro
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Support — DevLog by Philippe" description="Support DevLog and help keep the blog going.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16">

    <!-- Page Header -->
    <h1 class="font-heading text-4xl font-bold text-text-light dark:text-text mb-4">
      Support This Blog<span class="text-accent">.</span>
    </h1>
    <p class="text-lg text-muted mb-12">
      DevLog is free and always will be. No paywalls, no sponsored posts. If you find the content useful, here are some ways to show your support.
    </p>

    <!-- Buy Me a Coffee Section -->
    <section class="mb-12 p-8 rounded-xl border border-accent/30 bg-accent/5 text-center">
      <span class="text-4xl mb-4 block" aria-hidden="true">☕</span>
      <h2 class="font-heading text-2xl font-bold text-text-light dark:text-text mb-3">
        Buy Me a Coffee
      </h2>
      <p class="text-muted mb-6 max-w-md mx-auto">
        A small contribution goes a long way. It helps cover hosting, tools, and the time spent writing — and it means a lot.
      </p>
      <a
        href="#"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-bg-light dark:text-bg font-bold text-base hover:bg-accent-hover transition-colors"
        aria-label="Buy Me a Coffee (coming soon)"
      >
        <span aria-hidden="true">☕</span>
        Support on Buy Me a Coffee
      </a>
      <p class="text-xs text-muted mt-3">(Coming soon — link will be updated)</p>
    </section>

    <!-- Alternative Support Options -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text-light dark:text-text mb-6">
        Other Ways to Support
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <!-- Share -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border bg-surface-light dark:bg-surface text-center">
          <span class="text-3xl mb-3 block" aria-hidden="true">📢</span>
          <h3 class="font-heading font-bold text-text-light dark:text-text mb-2">Share a Post</h3>
          <p class="text-sm text-muted">
            Found something useful? Share it with a friend or on social media. Word of mouth is the best kind of support.
          </p>
        </div>

        <!-- Comment -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border bg-surface-light dark:bg-surface text-center">
          <span class="text-3xl mb-3 block" aria-hidden="true">💬</span>
          <h3 class="font-heading font-bold text-text-light dark:text-text mb-2">Leave a Comment</h3>
          <p class="text-sm text-muted">
            Every comment helps. Ask a question, share your take, or just say hi — it all fuels the blog.
          </p>
        </div>

        <!-- Star on GitHub -->
        <div class="p-6 rounded-xl border border-border-light dark:border-border bg-surface-light dark:bg-surface text-center">
          <span class="text-3xl mb-3 block" aria-hidden="true">⭐</span>
          <h3 class="font-heading font-bold text-text-light dark:text-text mb-2">Star on GitHub</h3>
          <p class="text-sm text-muted">
            The blog is open source. A star on the repo is a quick way to show appreciation.
          </p>
          <a
            href="https://github.com/PSthelyBlog/psthelyBlog.github.io"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block mt-3 text-sm text-accent hover:text-accent-hover transition-colors"
          >
            View on GitHub →
          </a>
        </div>
      </div>
    </section>

    <!-- About Link -->
    <section class="text-center py-8 border-t border-border-light dark:border-border">
      <p class="text-muted mb-2">Want to know more about the person behind the blog?</p>
      <a
        href="/about"
        class="text-accent hover:text-accent-hover font-medium transition-colors"
      >
        Read the About page →
      </a>
    </section>

  </div>
</BaseLayout>
