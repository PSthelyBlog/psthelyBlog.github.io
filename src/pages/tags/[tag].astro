---
// src/pages/tags/[tag].astro
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getPublishedPosts } from '@lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag);
    }
  }
  return Array.from(tagSet).map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter(p => p.data.tags.includes(tag)),
    },
  }));
}

interface Props {
  tag: string;
  posts: CollectionEntry<'posts'>[];
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag} — DevLog by Philippe`} description={`Posts tagged "${tag}" on DevLog.`}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-10">
      <a href="/tags" class="text-sm text-muted hover:text-accent transition-colors mb-2 inline-block">
        ← All Tags
      </a>
      <h1 class="font-heading text-4xl font-bold text-text-light dark:text-text">
        #<span class="text-accent">{tag}</span>
      </h1>
      <p class="text-muted mt-2">
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged with "{tag}"
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <PostCard post={post} />
      ))}
    </div>
  </div>
</BaseLayout>
