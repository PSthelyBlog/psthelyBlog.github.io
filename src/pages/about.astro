---
// src/pages/about.astro
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="About — DevLog by Philippe" description="About Philippe and the DevLog blog — mission, topics, and how to connect.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16">

    <!-- Author Section -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-12">
      <!-- Photo Placeholder -->
      <div class="shrink-0 w-32 h-32 rounded-full bg-surface-light dark:bg-surface border-2 border-accent/30 flex items-center justify-center">
        <span class="font-heading text-4xl text-accent" aria-hidden="true">P</span>
      </div>

      <!-- Name + Short Bio -->
      <div>
        <h1 class="font-heading text-4xl font-bold text-text-light dark:text-text mb-2">
          Hey, I'm Philippe<span class="text-accent">.</span>
        </h1>
        <p class="text-lg text-muted">
          Developer, writer, and the person behind DevLog. I build things for the web and write about what I learn along the way.
        </p>
      </div>
    </div>

    <!-- Mission Section -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text-light dark:text-text mb-4">
        Why This Blog Exists
      </h2>
      <div class="space-y-4 text-text-light dark:text-text leading-relaxed">
        <p>
          DevLog is a place to share practical knowledge, honest opinions, and lessons learned from building software. No hype, no fluff — just real talk about the tools and techniques that actually work.
        </p>
        <p>
          Everything here is free and always will be. I believe good developer content shouldn't be locked behind paywalls.
        </p>
      </div>
    </section>

    <!-- Topics Section -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text-light dark:text-text mb-4">
        What I Write About
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {[
          { emoji: '🌐', label: 'Web Development' },
          { emoji: '🤖', label: 'AI & Machine Learning' },
          { emoji: '🦀', label: 'Rust' },
          { emoji: '⚙️', label: 'DevOps' },
          { emoji: '🎨', label: 'Design Systems' },
          { emoji: '📈', label: 'Career & Growth' },
        ].map(topic => (
          <div class="flex items-center gap-2 p-3 rounded-lg border border-border-light dark:border-border bg-surface-light dark:bg-surface">
            <span aria-hidden="true">{topic.emoji}</span>
            <span class="text-sm font-medium text-text-light dark:text-text">{topic.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Connect Section -->
    <section class="mb-12">
      <h2 class="font-heading text-2xl font-bold text-text-light dark:text-text mb-4">
        Connect
      </h2>
      <div class="flex flex-wrap gap-3">
        <a
          href="https://github.com/PSthelyBlog"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border-light dark:border-border bg-surface-light dark:bg-surface text-text-light dark:text-text hover:border-accent/50 hover:text-accent transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
          GitHub
        </a>
        <a
          href="https://x.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border-light dark:border-border bg-surface-light dark:bg-surface text-text-light dark:text-text hover:border-accent/50 hover:text-accent transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
          X / Twitter
        </a>
        <a
          href="/rss.xml"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border-light dark:border-border bg-surface-light dark:bg-surface text-text-light dark:text-text hover:border-accent/50 hover:text-accent transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            <circle cx="5" cy="19" r="1" fill="currentColor" />
          </svg>
          RSS Feed
        </a>
      </div>
    </section>

    <!-- Support CTA -->
    <section class="p-8 rounded-xl border border-accent/30 bg-accent/5 text-center">
      <h2 class="font-heading text-2xl font-bold text-text-light dark:text-text mb-3">
        Support DevLog
      </h2>
      <p class="text-muted mb-6 max-w-md mx-auto">
        If you find the blog useful, consider supporting it. Every bit helps keep the content free and the lights on.
      </p>
      <a
        href="/support"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-bg-light dark:text-bg font-bold text-base hover:bg-accent-hover transition-colors"
      >
        <span aria-hidden="true">☕</span>
        Support the Blog
      </a>
    </section>

  </div>
</BaseLayout>
