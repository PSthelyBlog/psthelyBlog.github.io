import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="DevLog by Philippe" description="A developer blog by Philippe — web dev, AI, Rust, DevOps, design systems, and career.">
  <div class="mx-auto max-w-4xl px-4 py-24 text-center">
    <p class="font-heading text-accent text-sm tracking-widest uppercase mb-4">Welcome to</p>
    <h1 class="font-heading text-5xl sm:text-6xl font-bold text-text mb-6">
      DevLog<span class="text-accent">.</span>
    </h1>
    <p class="text-lg text-muted max-w-2xl mx-auto mb-8">
      A developer blog exploring web development, AI, Rust, DevOps, design systems, and the craft of building software.
    </p>
    <p class="text-sm text-muted">
      Shell &amp; Global UI complete. Next: Post Detail &amp; MDX Components.
    </p>
  </div>
</BaseLayout>
